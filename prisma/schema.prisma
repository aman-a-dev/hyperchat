generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =============== BETTER AUTH TABLES (DON'T MODIFY THESE) ===============

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?   @db.Text
  createdAt     DateTime
  updatedAt     DateTime
  
  // additional
  bio           String?
  job           String?
  country       String?
  
  // auth
  sessions      Session[]
  accounts      Account[]
  
  // chat
  messages      Message[]
  conversations Conversation[] @relation("ConversationParticipants")
  
  // settings
  settings      Settings?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
// =============== END BETTER AUTH TABLES ===============

// =============== YOUR CUSTOM TABLES ===============

model Conversation {
  id        String    @id @default(cuid())
  
  image     String?   @db.Text // For group chats
  name      String?   // For group chats
  isGroup   Boolean   @default(false)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  
  messages  Message[]
  users     User[]    @relation("ConversationParticipants")
  
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  
  // editing & replies
  edited         Boolean      @default(false)
  editedAt       DateTime?
  
  isAI           Boolean      @default(false)
  
  repliedToId    String?
  repliedTo      Message?     @relation("MessageReply", fields: [repliedToId], references: [id], onDelete: SetNull)
  replies        Message[]    @relation("MessageReply")
  
  forwardedFromId String?
  forwardedFrom   Message?     @relation("MessageForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwardedTo     Message[]    @relation("MessageForward")
  
  type           MessageType  @default(TEXT)
  
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Settings {
  id             String       @id @default(cuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Visibility Settings
  onlineStatusVisible Boolean  @default(true)
  lastSeenVisible     Boolean  @default(true)
  bioVisible          Boolean  @default(true)
  jobVisible          Boolean  @default(true)
  countryVisible      Boolean  @default(true)
  
  // Sync & Search Settings
  syncEmails      Boolean      @default(true)
  allowSearch     Boolean      @default(true)
  
  // Message Settings
  showTypingStatus Boolean      @default(true)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt
  
  @@map("settings")
}

enum MessageType {
  TEXT
  FILE
  IMAGE 
  VIDEO 
}